<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace ="restaurantMapper">
  
  	<select id="selectRestaurants" resultType="restaurant">
  		SELECT
  		       REST_NO
  		     , REST_NAME
  		     , CATEGORY
  		     , MIN_PRICE
  		     , DELIVERY_FEE
  		  FROM
  		       RESTAURANT
  		 ORDER
  		    BY
  		       REST_NO
  	</select>
  
  </mapper>